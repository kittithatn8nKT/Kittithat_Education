# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local.

# ---- Public (safe to ship to browser) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Server-only (NEVER expose to browser) ----
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role...
OPENAI_API_KEY=sk-...
# Cloud Vision API key, restricted to vision.googleapis.com only.
# Enable the API at https://console.cloud.google.com/apis/library/vision.googleapis.com
GOOGLE_VISION_API_KEY=AIza...
# Shared secret the OCR worker route requires when not invoked by Vercel Cron.
# Generate via: openssl rand -hex 32
OCR_WORKER_SECRET=

# ---- Optional ----
# RESEND_API_KEY=re_...                 # transactional email (Phase 4)
# SENTRY_DSN=https://...                # error tracking (Phase 5)
